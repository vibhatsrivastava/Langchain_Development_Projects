---
# Ansible playbook for {{ project_name }} agent
# Generated by AI Agent Builder CLI with AWX integration
# Project: {{ project_name }} ({{ architecture }} architecture)

- name: Execute {{ project_name }} AI Agent
  hosts: localhost
  gather_facts: false
  
  vars:
    project_dir: "{{ '{{' }} playbook_dir {{ '}}' }}/.."
    venv_path: "{{ '{{' }} project_dir {{ '}}' }}/.venv"
    python_executable: "{{ '{{' }} venv_path {{ '}}' }}/Scripts/python.exe"  # Windows
    # For Linux/Mac, use: "{{ '{{' }} venv_path {{ '}}' }}/bin/python"
    
  tasks:
    - name: Verify project virtual environment exists
      ansible.builtin.stat:
        path: "{{ '{{' }} venv_path {{ '}}' }}"
      register: venv_stat
      
    - name: Fail if venv not found
      ansible.builtin.fail:
        msg: "Virtual environment not found at {{ '{{' }} venv_path {{ '}}' }}. Run setup first."
      when: not venv_stat.stat.exists
    
    - name: Set agent execution environment variables
      ansible.builtin.set_fact:
        agent_env:
          # Ollama configuration (from AWX credentials)
          OLLAMA_BASE_URL: "{{ '{{' }} ollama_base_url | default('http://localhost:11434') {{ '}}' }}"
          OLLAMA_API_KEY: "{{ '{{' }} ollama_api_key | default('') {{ '}}' }}"
          OLLAMA_MODEL: "{{ '{{' }} ollama_model | default('gpt-oss:20b') {{ '}}' }}"
          
          # Langfuse observability (from AWX credentials, optional)
          LANGFUSE_ENABLED: "{{ '{{' }} langfuse_enabled | default('true') {{ '}}' }}"
          LANGFUSE_PUBLIC_KEY: "{{ '{{' }} langfuse_public_key | default('') {{ '}}' }}"
          LANGFUSE_SECRET_KEY: "{{ '{{' }} langfuse_secret_key | default('') {{ '}}' }}"
          LANGFUSE_HOST: "{{ '{{' }} langfuse_host | default('http://localhost:3000') {{ '}}' }}"
          
          # Agent-specific parameters (from AWX survey)
{%- if 'weather' in project_name.lower() %}
          CITY: "{{ '{{' }} city | default('London') {{ '}}' }}"
{%- elif 'github' in project_name.lower() %}
          GITHUB_TOKEN: "{{ '{{' }} github_token | default('') {{ '}}' }}"
          GITHUB_REPO: "{{ '{{' }} github_repo | default('') {{ '}}' }}"
          GITHUB_ISSUE_NUMBER: "{{ '{{' }} github_issue_number | default('') {{ '}}' }}"
{%- else %}
          # Add agent-specific parameters here (from survey)
          # CUSTOM_PARAM: "{{ '{{' }} custom_param | default('') {{ '}}' }}"
{%- endif %}
          
          # Logging
          LOG_LEVEL: "{{ '{{' }} log_level | default('INFO') {{ '}}' }}"
          
          # AWX metadata (for tracing/debugging)
          AWX_JOB_ID: "{{ '{{' }} tower_job_id | default('') {{ '}}' }}"
          AWX_JOB_TEMPLATE: "{{ '{{' }} tower_job_template_name | default('') {{ '}}' }}"
    
    - name: Execute agent via AWX wrapper
      ansible.builtin.command:
        cmd: "{{ '{{' }} python_executable {{ '}}' }} -m common.awx_wrapper {{ project_name }}"
        chdir: "{{ '{{' }} project_dir {{ '}}' }}/../.."
      environment: "{{ '{{' }} agent_env {{ '}}' }}"
      register: agent_output
      changed_when: false
      failed_when: agent_output.rc != 0
      
    - name: Parse agent output (JSON)
      ansible.builtin.set_fact:
        agent_result: "{{ '{{' }} agent_output.stdout | from_json {{ '}}' }}"
      when: agent_output.stdout | length > 0
      
    - name: Display agent result
      ansible.builtin.debug:
        var: agent_result
      when: agent_result is defined
      
    - name: Register result as Ansible fact (for downstream tasks)
      ansible.builtin.set_fact:
        {{ project_name | replace('-', '_') }}_result: "{{ '{{' }} agent_result {{ '}}' }}"
      when: agent_result is defined
      
    - name: Fail if agent execution failed
      ansible.builtin.fail:
        msg: "Agent execution failed: {{ '{{' }} agent_result.error {{ '}}' }}"
      when: 
        - agent_result is defined
        - agent_result.status == 'error'
