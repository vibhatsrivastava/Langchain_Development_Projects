---
# Custom AWX Credential Types for {{ project_name }}
# Import these into AWX: Settings → Credential Types → Add

# Ollama API Credential Type
- name: Ollama API Credentials
  description: Credentials for Ollama LLM server access
  kind: cloud
  inputs:
    fields:
      - id: ollama_base_url
        type: string
        label: Ollama Base URL
        help_text: URL of the Ollama server (e.g., http://ollama-server:11434)
        default: http://localhost:11434
      - id: ollama_api_key
        type: string
        label: Ollama API Key
        help_text: Bearer token for Ollama server (leave empty for local/unauthenticated)
        secret: true
      - id: ollama_model
        type: string
        label: Default Model
        help_text: Default LLM model to use
        default: gpt-oss:20b
  injectors:
    env:
      OLLAMA_BASE_URL: "{{ '{{' }} ollama_base_url {{ '}}' }}"
      OLLAMA_API_KEY: "{{ '{{' }} ollama_api_key {{ '}}' }}"
      OLLAMA_MODEL: "{{ '{{' }} ollama_model {{ '}}' }}"

# Langfuse Observability Credential Type (Optional)
- name: Langfuse Observability Credentials
  description: Credentials for Langfuse LLM tracing and observability
  kind: cloud
  inputs:
    fields:
      - id: langfuse_enabled
        type: string
        label: Enable Langfuse
        help_text: Enable or disable Langfuse tracing (true/false)
        default: "true"
      - id: langfuse_public_key
        type: string
        label: Langfuse Public Key
        help_text: Public API key from Langfuse dashboard
        secret: false
      - id: langfuse_secret_key
        type: string
        label: Langfuse Secret Key
        help_text: Secret API key from Langfuse dashboard
        secret: true
      - id: langfuse_host
        type: string
        label: Langfuse Host
        help_text: Langfuse server URL (cloud or self-hosted)
        default: http://localhost:3000
  injectors:
    env:
      LANGFUSE_ENABLED: "{{ '{{' }} langfuse_enabled {{ '}}' }}"
      LANGFUSE_PUBLIC_KEY: "{{ '{{' }} langfuse_public_key {{ '}}' }}"
      LANGFUSE_SECRET_KEY: "{{ '{{' }} langfuse_secret_key {{ '}}' }}"
      LANGFUSE_HOST: "{{ '{{' }} langfuse_host {{ '}}' }}"

{%- if 'github' in project_name.lower() %}

# GitHub API Credential Type
- name: GitHub API Credentials
  description: GitHub personal access token for repository access
  kind: cloud
  inputs:
    fields:
      - id: github_token
        type: string
        label: GitHub Token
        help_text: Personal access token with repo permissions
        secret: true
  injectors:
    env:
      GITHUB_TOKEN: "{{ '{{' }} github_token {{ '}}' }}"
{%- endif %}
