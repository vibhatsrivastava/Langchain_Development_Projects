{# Redis cache implementation #}
"""
redis_cache.py — Redis caching implementation.

Provides LLM response caching with TTL support.
"""

import os
import sys
from typing import Optional, Any
import json

# Add repo root to path for imports
sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '..', '..', '..')))

import redis
from langchain_redis import RedisCache
from common.utils import get_logger, require_env

logger = get_logger(__name__)


class RedisCacheManager:
    """
    Redis cache manager for LLM responses.
    
    Wraps Redis client with LangChain-specific caching.
    """
    
    def __init__(self):
        """Initialize Redis connection from environment."""
        self.host = require_env("REDIS_HOST")
        self.port = int(require_env("REDIS_PORT"))
        self.db = int(os.getenv("REDIS_DB", "0"))
        self.password = os.getenv("REDIS_PASSWORD", "")
        self.ttl = int(os.getenv("REDIS_TTL", "3600"))
        
        # Create Redis client
        self.client = redis.Redis(
            host=self.host,
            port=self.port,
            db=self.db,
            password=self.password if self.password else None,
            decode_responses=True,
        )
        
        # Test connection
        try:
            self.client.ping()
            logger.info(f"Connected to Redis at {self.host}:{self.port} (db={self.db})")
        except redis.ConnectionError as e:
            logger.error(f"Failed to connect to Redis: {e}")
            raise
        
        # Initialize LangChain Redis cache
        self.langchain_cache = RedisCache(redis_=self.client, ttl=self.ttl)
    
    def set(self, key: str, value: Any, ttl: Optional[int] = None) -> bool:
        """
        Set a cache value.
        
        Args:
            key: Cache key
            value: Value to cache (will be JSON-serialized)
            ttl: Time-to-live in seconds (default: from REDIS_TTL env)
        
        Returns:
            True if successful
        """
        ttl = ttl or self.ttl
        serialized_value = json.dumps(value)
        result = self.client.setex(key, ttl, serialized_value)
        logger.debug(f"Cached key '{key}' with TTL {ttl}s")
        return bool(result)
    
    def get(self, key: str) -> Optional[Any]:
        """
        Get a cache value.
        
        Args:
            key: Cache key
        
        Returns:
            Deserialized value or None if not found
        """
        value = self.client.get(key)
        if value is None:
            logger.debug(f"Cache miss for key '{key}'")
            return None
        
        logger.debug(f"Cache hit for key '{key}'")
        return json.loads(value)
    
    def delete(self, key: str) -> bool:
        """
        Delete a cache key.
        
        Args:
            key: Cache key to delete
        
        Returns:
            True if key was deleted
        """
        result = self.client.delete(key)
        logger.debug(f"Deleted key '{key}'")
        return bool(result)
    
    def clear(self):
        """Clear all keys in the current database."""
        self.client.flushdb()
        logger.warning("Cleared all Redis cache keys")
    
    def get_langchain_cache(self) -> RedisCache:
        """
        Get LangChain Redis cache instance.
        
        Returns:
            RedisCache for use with LangChain
        """
        return self.langchain_cache


def get_cache() -> RedisCacheManager:
    """
    Get or create Redis cache manager.
    
    Returns:
        RedisCacheManager instance
    """
    return RedisCacheManager()
