{# pgvector vector store implementation #}
"""
vector_store.py — PostgreSQL pgvector vector store implementation.

Manages vector embeddings using PostgreSQL + pgvector extension.
"""

import os
import sys
from typing import List, Optional

# Add repo root to path for imports
sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '..', '..', '..')))

import psycopg2
from langchain_postgres import PGVector
from langchain_core.documents import Document
from common.llm_factory import get_embeddings
from common.utils import get_logger, require_env

logger = get_logger(__name__)


class PgVectorStore:
    """
    PostgreSQL pgvector vector store wrapper.
    
    Provides high-level interface for vector operations.
    """
    
    def __init__(self):
        """Initialize pgvector store with connection from environment."""
        self.host = require_env("POSTGRES_HOST")
        self.port = require_env("POSTGRES_PORT")
        self.database = require_env("POSTGRES_DB")
        self.user = require_env("POSTGRES_USER")
        self.password = require_env("POSTGRES_PASSWORD")
        
        self.connection_string = (
            f"postgresql://{self.user}:{self.password}@{self.host}:{self.port}/{self.database}"
        )
        
        self.embeddings = get_embeddings()
        self.collection_name = "langchain_vectors"
        
        # Initialize PGVector store
        self.store = PGVector(
            connection_string=self.connection_string,
            embedding_function=self.embeddings,
            collection_name=self.collection_name,
        )
        
        logger.info(f"Connected to pgvector at {self.host}:{self.port}/{self.database}")
    
    def add_documents(self, documents: List[Document]) -> List[str]:
        """
        Add documents to vector store.
        
        Args:
            documents: List of LangChain Document objects
        
        Returns:
            List of document IDs
        """
        logger.info(f"Adding {len(documents)} documents to vector store")
        ids = self.store.add_documents(documents)
        logger.info(f"Successfully added {len(ids)} documents")
        return ids
    
    def similarity_search(
        self,
        query: str,
        k: int = 4,
        filter: Optional[dict] = None
    ) -> List[Document]:
        """
        Search for similar documents.
        
        Args:
            query: Search query
            k: Number of results to return
            filter: Optional metadata filter
        
        Returns:
            List of similar documents
        """
        logger.info(f"Searching for '{query}' (k={k})")
        results = self.store.similarity_search(query, k=k, filter=filter)
        logger.info(f"Found {len(results)} similar documents")
        return results
    
    def delete_collection(self):
        """Delete the entire collection."""
        logger.warning(f"Deleting collection: {self.collection_name}")
        self.store.delete_collection()


def get_vector_store() -> PgVectorStore:
    """
    Get or create pgvector store singleton.
    
    Returns:
        PgVectorStore instance
    """
    return PgVectorStore()
