# ─── Ollama Server ──────────────────────────────────────────────────────────
# URL of the Ollama server (remote hosted or local)
# For remote: https://your-ollama-server.example.com
# For local:  http://localhost:11434
OLLAMA_BASE_URL=https://your-ollama-server.example.com

# API key (Bearer token) for authenticating with the Ollama server.
# Required for remote/hosted deployments. Leave blank for unauthenticated local Ollama.
OLLAMA_API_KEY=your_api_key_here

# ─── Models ─────────────────────────────────────────────────────────────────
# Default LLM model to use across all projects.
# Change this to any model available on your Ollama server or pulled locally.
# See docs/models.md for a full list of alternatives and pull commands.
OLLAMA_MODEL=gpt-oss:20b

# Default embedding model used for RAG and vector store projects.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── App Settings ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Langfuse Observability (Always-On by Default) ──────────────────────────
# Automatic LLM tracing, cost tracking, and performance analytics.
# All LLM calls are traced automatically via common/llm_factory — no code changes needed.
# Set LANGFUSE_ENABLED=false to disable tracing globally.

# Enable or disable Langfuse tracing (default: true for always-on behavior)
LANGFUSE_ENABLED=true

# Langfuse API keys (get from Langfuse dashboard: Settings → API Keys)
# Create a project at your Langfuse instance and generate keys
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here

# Langfuse server URL (cloud or self-hosted)
# Cloud: https://cloud.langfuse.com
# Self-hosted: http://your-langfuse-server:3000
LANGFUSE_HOST=http://10.0.0.15:3000

# ─── Integration-Specific Variables ──────────────────────────────────────────
# Integration-specific variables (GITHUB_*, REDIS_*, PGVECTOR_*, etc.) should be
# defined in project-level .env files, NOT in this root .env file.
#
# Example: projects/04_github_issue_reporter/.env contains GITHUB_TOKEN, etc.
#
# This keeps the root .env clean and scoped to common/shared variables only.
# Projects automatically load both root .env (common) and project .env (integrations).

# ─── HashiCorp Vault (Optional) ──────────────────────────────────────────────
# Enable centralized secret management via HashiCorp Vault.
# When enabled, secrets (OLLAMA_API_KEY, LANGFUSE_*_KEY, etc.) are fetched from
# Vault with automatic fallback to .env file.
# Set to 'false' to use .env file only (default for backward compatibility).
VAULT_ENABLED=false

# HashiCorp Vault server URL (e.g., http://vault.example.com:8200)
# Required when VAULT_ENABLED=true
VAULT_ADDR=http://vault.example.com:8200

# Vault authentication token (generated via 'vault login' or AppRole)
# Required when VAULT_ENABLED=true
VAULT_TOKEN=your_vault_token_here

# Path to the secret in Vault (without mount point prefix)
# Example: "ollama" will read from secret/data/ollama (KV v2 engine)
# Note: Langfuse keys are stored under separate path "langfuse" in Vault
VAULT_SECRET_PATH=ollama

# Vault mount point for KV secrets engine (default: "secret")
# Change if your Vault uses a different mount point
VAULT_MOUNT_POINT=secret
