# ─── Ollama Server ──────────────────────────────────────────────────────────
# URL of the Ollama server (remote hosted or local)
# For remote: https://your-ollama-server.example.com
# For local:  http://localhost:11434
OLLAMA_BASE_URL=https://your-ollama-server.example.com

# API key (Bearer token) for authenticating with the Ollama server.
# Required for remote/hosted deployments. Leave blank for unauthenticated local Ollama.
OLLAMA_API_KEY=your_api_key_here

# ─── Models ─────────────────────────────────────────────────────────────────
# Default LLM model to use across all projects.
# Change this to any model available on your Ollama server or pulled locally.
# See docs/models.md for a full list of alternatives and pull commands.
OLLAMA_MODEL=gpt-oss:20b

# Default embedding model used for RAG and vector store projects.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── App Settings ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
